NODE_ENV=development
PORT=4000

# Host port matches docker-compose.yml, which maps host 55432 -> container 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:55432/anvilnote?schema=public"

CORS_ORIGIN="http://localhost:3000,http://localhost:5173,http://localhost:5174"
# Allow credentialed cross-origin requests. There is no auth/cookie layer yet,
# so this currently has no practical effect; left enabled for when one lands.
CORS_CREDENTIALS=true

STORAGE_DIR="./storage"
TYPST_STORAGE_DIR="./storage/typst"
PDF_STORAGE_DIR="./storage/pdf"

ANVILNOTE_RENDERER_PATH="../anvilnote-renderer"
TYPST_BIN="typst"

# Required for stats/function charts (anvilnote-charts's CLI) to use the
# bundled fonts and get consistent fontFamily rendering — unlike
# anvilnote-renderer's own font resolution, anvilnote-charts has no local
# fallback of its own; leaving this unset silently falls back to Typst's
# system font search (wrong glyph metrics, fontFamily becomes a no-op).
ANVILNOTE_FONT_DIR="../anvilnote-renderer/fonts"

# Render artifacts (.typ/.pdf) older than this are swept on startup and after
# each render to keep storage bounded.
RENDER_RETENTION_HOURS=24
