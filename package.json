{
  "name": "anvilnote-api",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js/Express API for AnvilNote document storage and Typst PDF rendering.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:desktop": "prisma generate && prisma generate --schema prisma/sqlite.prisma && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:sqlite": "prisma generate --schema prisma/sqlite.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "generate:template-previews": "node scripts/generate-template-previews.mjs",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "prisma": "^6.16.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
