generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id               String            @id @default(cuid())
  title            String
  content          Json
  // Document Metadata: title/author/date/courseName… — kept across templates.
  metadata         Json?
  // Template Options: showToc/paperSize… — bound to the current template.
  templateSettings Json?
  // Document-level, template-independent: whether PDF export shows
  // "1"/"1.1"-style heading numbers. Deliberately NOT part of
  // templateSettings — it applies uniformly regardless of which
  // template is active (only plain-note's own adapter chain currently
  // acts on it; see anvilnote-renderer's supportsNumberedHeadings
  // manifest capability flag for how other templates are protected
  // from an argument they don't declare).
  numberedHeadings Boolean           @default(true)
  // Document-level, template-independent, same reasoning as
  // numberedHeadings above: adjustable page margins, in cm. null (the
  // default) means "use the active template's own built-in margins" —
  // each side is an independent partial override (only plain-note's
  // adapter chain currently acts on these; see anvilnote-renderer's
  // supportsCustomMargins manifest capability flag).
  marginTopCm      Float?
  marginBottomCm   Float?
  marginLeftCm     Float?
  marginRightCm    Float?
  // Template slug (file-based template, not a DB foreign key).
  templateId       String?
  typstSource      String?
  // Optional grouping. Deleting a project unfiles its documents (SET NULL).
  projectId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  renderOutputs    RenderOutput[]
  versions         DocumentVersion[]
}

// A point-in-time snapshot of a document's versioned fields, for the
// version-history feature. Snapshots are created client-side (on an
// interval, only when content actually changed since the last one — see
// anvilnote-web's document-store.ts) rather than on every autosave, since a
// snapshot per keystroke-debounce would be far too granular to be a useful
// "version" and would bloat storage for no benefit.
model DocumentVersion {
  id               String   @id @default(cuid())
  documentId       String
  title            String
  content          Json
  metadata         Json?
  templateSettings Json?
  numberedHeadings Boolean  @default(true)
  marginTopCm      Float?
  marginBottomCm   Float?
  marginLeftCm     Float?
  marginRightCm    Float?
  createdAt        DateTime @default(now())

  document         Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model Project {
  id        String     @id @default(cuid())
  name      String
  // Lucide icon name (e.g. "folder", "book-open"); null falls back to a default.
  icon      String?
  // Free-form tags, stored as a JSON array of strings.
  tags      Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  documents Document[]
}

model RenderOutput {
  id               String       @id @default(cuid())
  documentId       String
  templateId       String?
  templateVersion  String?
  format           String       @default("pdf")
  status           RenderStatus  @default(PROCESSING)
  typstPath        String?
  pdfPath          String?
  pdfUrl           String?
  error            String?
  // Immutable snapshots captured at render time.
  contentSnapshot  Json?
  metadataSnapshot Json?
  templateSnapshot Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  document         Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

enum RenderStatus {
  PROCESSING
  COMPLETED
  FAILED
}
