generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id          String    @id @default(cuid())
  title       String
  content     Json
  metadata    Json?
  typstSource String?
  templateId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  template    Template? @relation(fields: [templateId], references: [id])
  renders     RenderJob[]
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  config      Json?
  typstBody   String?
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   Document[]
}

model RenderJob {
  id         String       @id @default(cuid())
  documentId String
  status     RenderStatus @default(QUEUED)
  typstPath  String?
  pdfPath    String?
  pdfUrl     String?
  error      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  document   Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

enum RenderStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}
