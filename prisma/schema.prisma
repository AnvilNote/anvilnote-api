generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id               String         @id @default(cuid())
  title            String
  content          Json
  // Document Metadata: title/author/date/courseName… — kept across templates.
  metadata         Json?
  // Template Options: showToc/paperSize… — bound to the current template.
  templateSettings Json?
  // Template slug (file-based template, not a DB foreign key).
  templateId       String?
  typstSource      String?
  // Optional grouping. Deleting a project unfiles its documents (SET NULL).
  projectId        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  renderOutputs    RenderOutput[]
}

model Project {
  id        String     @id @default(cuid())
  name      String
  // Lucide icon name (e.g. "folder", "book-open"); null falls back to a default.
  icon      String?
  // Free-form tags, stored as a JSON array of strings.
  tags      Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  documents Document[]
}

model RenderOutput {
  id               String       @id @default(cuid())
  documentId       String
  templateId       String?
  templateVersion  String?
  format           String       @default("pdf")
  status           RenderStatus  @default(PROCESSING)
  typstPath        String?
  pdfPath          String?
  pdfUrl           String?
  error            String?
  // Immutable snapshots captured at render time.
  contentSnapshot  Json?
  metadataSnapshot Json?
  templateSnapshot Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  document         Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

enum RenderStatus {
  PROCESSING
  COMPLETED
  FAILED
}
